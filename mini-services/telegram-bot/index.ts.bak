// ── /code command (verify admin) ───────────────────────────
bot.command('code', async (ctx) => {
  if (!ctx.chat || ctx.chat.type !== 'private') return

  const parts = ctx.message?.text?.split(' ')
  if (!parts || parts.length < 2) {
    await ctx.reply('❌ الصيغة: /code YOUR_PASSWORD')
    return
  }

  const password = parts.slice(1).join(' ')

  try {
    const admins = await sbGet('Admin')
    const admin = admins.find((a: any) => a.password === password)

    if (admin) {
      const chatId = ctx.chat.id
      await sbPatch('Admin', `id=eq.${admin.id}`, { telegramChatId: chatId.toString() })
      authorizedChats.add(chatId)
      await loadAuthorizedChats()

      await ctx.reply(
        `✅ تم ربط حسابك بنجاح!\n\n` +
        `مرحباً ${admin.name} 🎉\n` +
        `الآن يمكنك رفع الصور واستخدام البوت`
      )
    } else {
      await ctx.reply('❌ كود خاطئ، تأكد من كلمة المرور')
    }
  } catch (e) {
    console.error('Register error:', e)
    await ctx.reply('❌ حدث خطأ، حاول مرة أخرى')
  }
})


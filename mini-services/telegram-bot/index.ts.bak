const PORT = 3030

// ── Supabase helpers ───────────────────────────────────────
const sbHeaders = () => ({
  'apikey': SUPABASE_KEY,
  'Authorization': `Bearer ${SUPABASE_KEY}`,
  'Content-Type': 'application/json',
})

async function sbGet(table: string, query?: string): Promise<any[]> {
  const url = `${SUPABASE_URL}/rest/v1/${table}${query ? '?' + query : ''}`
  const res = await fetch(url, { headers: sbHeaders() })
  if (!res.ok) throw new Error(`Supabase GET error: ${res.status}`)
  return res.json()
}

async function sbPost(table: string, data: Record<string, unknown>): Promise<any> {
  const url = `${SUPABASE_URL}/rest/v1/${table}`
  const res = await fetch(url, {
    method: 'POST',
    headers: { ...sbHeaders(), Prefer: 'return=representation' },
    body: JSON.stringify({ ...data, id: crypto.randomUUID(), createdAt: new Date().toISOString(), updatedAt: new Date().toISOString() }),
  })
  if (!res.ok) throw new Error(`Supabase POST error: ${res.status}`)
  const result = await res.json()
  return result[0]
}

async function sbDelete(table: string, filter: string): Promise<void> {
  const url = `${SUPABASE_URL}/rest/v1/${table}?${filter}`
  const res = await fetch(url, { method: 'DELETE', headers: sbHeaders() })
  if (!res.ok) throw new Error(`Supabase DELETE error: ${res.status}`)
}

async function sbPatch(table: string, filter: string, data: Record<string, unknown>): Promise<any> {
  const url = `${SUPABASE_URL}/rest/v1/${table}?${filter}`
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { ...sbHeaders(), Prefer: 'return=representation' },
    body: JSON.stringify({ ...data, updatedAt: new Date().toISOString() }),
  })
  if (!res.ok) throw new Error(`Supabase PATCH error: ${res.status}`)
  const result = await res.json()
  return result[0]
}

// ── Authorized chat IDs ────────────────────────────────────
let authorizedChats: Set<number> = new Set([ADMIN_ACCOUNT_ID])

async function loadAuthorizedChats() {
  try {
    const admins = await sbGet('Admin')
    authorizedChats = new Set([ADMIN_ACCOUNT_ID])
    for (const a of admins) {
      if (a.telegramChatId) {
        authorizedChats.add(parseInt(a.telegramChatId))
      }
    }
    console.log(`✅ Authorized chats: ${Array.from(authorizedChats).join(', ')}`)
  } catch (e) {
    console.error('Failed to load authorized chats:', e)
  }
}

// ── Create Bot ─────────────────────────────────────────────
const bot = new Bot(BOT_TOKEN)
bot.api.config.useBotApi = true

// ── Albums ─────────────────────────────────────────────────
const ALBUMS = [
  'حلقات تحفيظية', 'سرد قرآني', 'دورات سنوية', 'مسابقات سنوية',
  'تكريم', 'احتفالات خريجين', 'متميزين', 'خريجون', 'أخرى'
]

// ── Pending media (waiting for album selection) ────────────
interface PendingMedia {
  chatId: number
  messageId: number
  fileId: string
  caption?: string
}
const pendingMedia: Map<number, PendingMedia> = new Map()

// ── Middleware: Authorization ──────────────────────────────
bot.use(async (ctx, next) => {
  const chatId = ctx.chat?.id
  if (!chatId) return next()

  // Always allow commands and callbacks in private chats
  if (ctx.chat?.type === 'private') {
    return next()
  }

  // For groups/channels, check authorization
  if (!authorizedChats.has(chatId) && ctx.from && !authorizedChats.has(ctx.from.id)) {
    return next()
  }

  return next()
})


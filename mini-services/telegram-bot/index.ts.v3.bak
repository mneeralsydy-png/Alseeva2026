async function handleAddCircleText(ctx: any, text: string) {
  const chatId = ctx.chat!.id
  const st = getState(chatId)

  switch (st.step) {
    case 1: {
      if (!text.trim()) {
        await ctx.reply('❌ اسم الحلقة مطلوب', { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() })
        return
      }
      st.data.name = text.trim()
      st.step = 2
      await ctx.reply(
        `➕ ${bold('إضافة حلقة جديدة')}\n\n` +
        `📚 ${bold('الخطوة 2 من 5')}\n\n👨‍🏫 أدخل اسم المعلم:`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break

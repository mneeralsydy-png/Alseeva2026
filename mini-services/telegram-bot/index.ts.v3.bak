// ═══════════════════════════════════════════════════════════════════════
interface PendingMedia {
  chatId: number
  messageId: number
  fileId: string
  caption?: string
}
const pendingMedia: Map<number, PendingMedia> = new Map()

// ═══════════════════════════════════════════════════════════════════════
// Bot Setup
// ═══════════════════════════════════════════════════════════════════════
const bot = new Bot(BOT_TOKEN)

// ─── Auth Middleware — check if user is authenticated ────────────────
bot.use(async (ctx, next) => {
  const chatId = ctx.chat?.id
  if (!chatId || ctx.chat?.type !== 'private') return next()

  const text = ctx.message?.text || ''
  const isCommand = ctx.message?.text?.startsWith('/')
  const isCallback = ctx.updateType === 'callback_query'

  // Allow these commands even without auth
  if (isCommand && (text === '/start' || text === '/login' || text === '/code')) {
    return next()
  }

  // Allow callback queries for auth flow
  if (isCallback) {
    const data = (ctx.callbackQuery as any).data
    if (data === 'cancel') return next()
    // For non-auth callbacks, check auth
    if (!authenticatedChats.has(chatId) && !pendingAuth.has(chatId)) {
      await ctx.answerCallbackQuery({ text: '🔒 يرجى تسجيل الدخول أولاً' })
      return
    }
    return next()
  }

  // For text messages during auth flow
  if (pendingAuth.has(chatId)) {
    return next()
  }

  // For regular messages, require auth
  if (!authenticatedChats.has(chatId) && !isCommand) {
    await ctx.reply(
      '🔒 لم يتم تسجيل الدخول\n\n' +
      'أرسل /login أو /start لتسجيل الدخول',
      { reply_markup: new Keyboard().text('🔐 تسجيل الدخول').oneTime().resized() }
    )
    return
  }

  return next()
})


async function showBotInfo(ctx: any, chatId: number) {
  const uptime = process.uptime()
  const hours = Math.floor(uptime / 3600)
  const mins = Math.floor((uptime % 3600) / 60)

  await ctx.reply(
    `ℹ️ ${bold('معلومات البوت')}\n${sep()}\n\n` +
    `🤖 الإصدار: v3\\.0\n` +
    `⏱️ وقت التشغيل: ${hours}س ${mins}د\n` +
    `📡 القناة: ${CHANNEL_ID}\n` +
    `👥 المستخدمين المصرح لهم: ${authenticatedChats.size}`,
    { parse_mode: 'MarkdownV2', reply_markup: backBtn() }
  )
}

// ═══════════════════════════════════════════════════════════════════════
// Error Handler
// ═══════════════════════════════════════════════════════════════════════
bot.catch((err) => {
  console.error('Bot error:', err)
})

// ═══════════════════════════════════════════════════════════════════════
// Start Bot — LONG POLLING ONLY (no webhook!)
// ═══════════════════════════════════════════════════════════════════════
async function main() {
  console.log('🚀 Starting AlShifa Telegram Bot v3.0...')

  // Load authorized chats from database
  await loadAuthorizedChats()

  // Delete any existing webhook to prevent conflicts
  try {
    await bot.api.deleteWebhook({ drop_pending_updates: true })
    console.log('✅ Cleared any existing webhook')
  } catch (e) {
    console.error('Failed to clear webhook:', e)
  }

  // Start polling (Grammy handles offset tracking automatically)
  bot.start({
    onStart: (info) => {
      console.log(`✅ Bot @${info.username} started successfully!`)
      console.log(`📡 Channel: ${CHANNEL_ID}`)
      console.log(`👤 Admin: ${ADMIN_ACCOUNT_ID}`)
      console.log(`👥 Authorized chats: ${authenticatedChats.size}`)
    },
  })
}

main().catch((err) => {
  console.error('Fatal error:', err)
  process.exit(1)
})

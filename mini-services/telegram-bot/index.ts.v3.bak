    .text('⚙️ الإعدادات')
    .resized()
    .persistent()
}

function backBtn(): InlineKeyboard {
  return new InlineKeyboard().text('🏠 القائمة الرئيسية', 'back_main')
}

function cancelBtn(): InlineKeyboard {
  return new InlineKeyboard().text('❌ إلغاء', 'cancel')
}

// ═══════════════════════════════════════════════════════════════════════
// Authorization — Track authenticated chats
// ═══════════════════════════════════════════════════════════════════════
const authenticatedChats: Set<number> = new Set()

// Track pending password entry
const pendingAuth: Map<number, boolean> = new Map()

async function loadAuthorizedChats() {
  try {
    const admins = await sbGet('Admin')
    authenticatedChats.clear()
    authenticatedChats.add(ADMIN_ACCOUNT_ID)
    for (const a of admins) {
      if (a.telegramChatId) authenticatedChats.add(parseInt(a.telegramChatId))
    }
    console.log(`✅ Authorized chats loaded: ${authenticatedChats.size} chats`)
  } catch (e) {
    console.error('Failed to load authorized chats:', e)
  }
}


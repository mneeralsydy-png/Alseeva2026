    case 3: {
      st.data.time = text.trim()
      st.step = 4
      await ctx.reply(
        `➕ ${bold('إضافة حلقة جديدة')}\n\n` +
        `📚 ${bold('الخطوة 4 من 5')}\n\n📍 أدخل مكان الحلقة:`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
    case 4: {
      st.data.location = text.trim()
      st.step = 5
      const kb = new InlineKeyboard()

async function showAttHalakat(ctx: any, chatId: number, mode: string) {
  try {
    const halakat = await sbGet('Halaka', 'order=createdAt.desc')
    if (halakat.length === 0) {
      await ctx.reply('❌ لا توجد حلقات مسجلة', { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
      return
    }

    const kb = new InlineKeyboard()
    halakat.forEach((h: any) => {
      kb.text(`🏫 ${h.name}`, `att_hsel_${h.id}_${mode}`).row()
    })
    kb.row().text('🏠 القائمة الرئيسية', 'back_main')

    await ctx.reply(
      mode === 'today'
        ? `📅 ${bold('حضور اليوم')} — اختر الحلقة:`
        : `📊 ${bold('تقرير الحضور')} — اختر الحلقة:`,
      { parse_mode: 'MarkdownV2', reply_markup: kb }
    )
  } catch (e) {
    console.error('Att halakat error:', e)
    await ctx.reply('❌ حدث خطأ', { parse_mode: 'MarkdownV2' })
  }
}

async function showAttStudents(ctx: any, chatId: number, halakaId: string, page: number) {
  try {
    const students = await sbGet('Student', `halakaId=eq.${halakaId}&order=createdAt.desc`)
    if (students.length === 0) {
      await ctx.reply('❌ لا يوجد طلاب في هذه الحلقة', { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
      return
    }

    const today = new Date().toISOString().split('T')[0]
    const existingAtt = await sbGet('Attendance', `date=eq.${today}&halakaId=eq.${halakaId}`)
    const attMap = new Map(existingAtt.map((a: any) => [a.studentId, a]))

    const total = Math.ceil(students.length / ATT_PAGE_SIZE)
    const slice = students.slice(page * ATT_PAGE_SIZE, (page + 1) * ATT_PAGE_SIZE)

    let msg = `📋 ${bold('حضور اليوم')}\n`
    msg += `📄 الصفحة ${page + 1}/${total}\n${sep()}\n\n`

    const kb = new InlineKeyboard()
    for (const s of slice) {
      const status = attMap.get(s.id)?.status || 'حاضر'
      const icon = status === 'حاضر' ? '✅' : status === 'غائب' ? '❌' : '⚠️'
      msg += `${icon} ${esc(s.name || 'بدون اسم')} — ${esc(status)}\n`
      kb.text(`${status === 'حاضر' ? '✅' : '☐'} ${s.name}`, `att_mark_${s.id}_${halakaId}_حاضر`)
      kb.text(`${status === 'غائب' ? '❌' : '☐'} ${s.name}`, `att_mark_${s.id}_${halakaId}_غائب`)
      kb.text(`⚠️ تأخر`, `att_mark_${s.id}_${halakaId}_متأخر`).row()
    }

    if (page > 0) kb.text('⬅️ السابق', `att_pg_${halakaId}_${page - 1}`)
    if (page < total - 1) kb.text('➡️ التالي', `att_pg_${halakaId}_${page + 1}`)
    kb.row().text('🏠 القائمة الرئيسية', 'back_main')

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: kb })
  } catch (e) {
    console.error('Att students error:', e)
    await ctx.reply('❌ حدث خطأ في تحميل الطلاب', { parse_mode: 'MarkdownV2' })
  }
}

async function markAttendance(ctx: any, chatId: number, studentId: string, halakaId: string, status: string) {
  try {
    const today = new Date().toISOString().split('T')[0]
    const existing = await sbGet('Attendance', `studentId=eq.${studentId}&date=eq.${today}&halakaId=eq.${halakaId}`)

    if (existing.length > 0) {
      await sbPatch('Attendance', `id=eq.${existing[0].id}`, { status })
    } else {
      await sbPost('Attendance', { studentId, date: today, halakaId, status })
    }

    const statusIcon = status === 'حاضر' ? '✅' : status === 'غائب' ? '❌' : '⚠️'
    await ctx.reply(`${statusIcon} تم تحديث الحضور: ${esc(status)}`, { parse_mode: 'MarkdownV2' })
  } catch (e) {
    console.error('Mark attendance error:', e)
    await ctx.reply('❌ حدث خطأ في تحديث الحضور', { parse_mode: 'MarkdownV2' })
  }
}

async function showAttReport(ctx: any, chatId: number, halakaId: string) {
  try {
    const students = await sbGet('Student', `halakaId=eq.${halakaId}&order=createdAt.desc`)
    const now = new Date()
    const firstDay = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0]
    const lastDay = now.toISOString().split('T')[0]

    const att = await sbGet('Attendance', `halakaId=eq.${halakaId}&date=gte.${firstDay}&date=lte.${lastDay}`)

    let msg = `📊 ${bold('تقرير الحضور الشهري')}\n`
    msg += `📅 من ${esc(firstDay)} إلى ${esc(lastDay)}\n${sep()}\n\n`

    for (const s of students) {
      const stuAtt = att.filter((a: any) => a.studentId === s.id)
      const present = stuAtt.filter((a: any) => a.status === 'حاضر').length
      const total = stuAtt.length || 1
      const pct = Math.round((present / total) * 100)
      const icon = pct >= 75 ? '🟢' : pct >= 50 ? '🟡' : '🔴'
      msg += `${icon} ${esc(s.name || 'بدون اسم')}: ${present}/${stuAtt.length} \\(${pct}%\\)\n`
    }

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
  } catch (e) {
    console.error('Att report error:', e)
    await ctx.reply('❌ حدث خطأ في التقرير', { parse_mode: 'MarkdownV2' })
  }
}


    case 2: {
      st.data.teacher = text.trim()
      st.step = 3
      await ctx.reply(
        `➕ ${bold('إضافة حلقة جديدة')}\n\n` +
        `📚 ${bold('الخطوة 3 من 5')}\n\n🕐 أدخل موعد الحلقة \\(مثال: 4:00 \\- 5:30 مساءً\\):`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break

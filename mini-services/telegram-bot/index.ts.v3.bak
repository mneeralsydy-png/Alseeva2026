    kb.row().text('🏠 القائمة الرئيسية', 'back_main')

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: kb })
  } catch (e) {
    console.error('Circles list error:', e)
    await ctx.reply('❌ حدث خطأ في تحميل قائمة الحلقات', { parse_mode: 'MarkdownV2' })

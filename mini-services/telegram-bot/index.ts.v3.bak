async function showAlbums(ctx: any, chatId: number) {
  try {
    const images = await sbGet('MediaImage', 'order=createdAt.desc&limit=100')
    if (images.length === 0) {
      await ctx.reply('📷 لا توجد صور بعد', { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
      return
    }

    const albums = new Map<string, number>()
    for (const img of images) {
      const album = img.album || 'أخرى'
      albums.set(album, (albums.get(album) || 0) + 1)
    }

    let msg = `📁 ${bold('الألبومات')}\n${sep()}\n\n`
    albums.forEach((count, name) => {
      msg += `📂 ${bold(name)}: ${count} صورة\n`
    })

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
  } catch (e) {
    console.error('Albums error:', e)
    await ctx.reply('❌ حدث خطأ', { parse_mode: 'MarkdownV2' })
  }
}

async function saveMediaToAlbum(ctx: any, chatId: number, albumIdx: number) {
  const media = pendingMedia.get(chatId)
  if (!media) {
    await ctx.reply('❌ لا توجد صورة معلقة', { parse_mode: 'MarkdownV2' })
    return
  }

  const albumName = ALBUMS[albumIdx]
  try {
    await sbPost('MediaImage', {
      url: `tg:${media.fileId}`,
      album: albumName,
      type: 'telegram',
    })
    pendingMedia.delete(chatId)

    await ctx.reply(
      `✅ ${bold('تم حفظ الصورة بنجاح\\!')}\n\n` +
      `📁 الألبوم: ${esc(albumName)}`,
      { parse_mode: 'MarkdownV2', reply_markup: backBtn() }
    )
  } catch (e) {
    console.error('Save media error:', e)
    await ctx.reply('❌ حدث خطأ في حفظ الصورة', { parse_mode: 'MarkdownV2' })
  }
}


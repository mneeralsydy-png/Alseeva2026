async function showActivitiesList(ctx: any, chatId: number, page: number) {
  try {
    const activities = await sbGet('Activity', 'order=createdAt.desc')

    if (activities.length === 0) {
      await ctx.reply('📋 لا توجد أنشطة مسجلة', { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
      return
    }

    const total = Math.ceil(activities.length / PAGE_SIZE)
    const slice = activities.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE)

    let msg = `📋 ${bold('قائمة الأنشطة')}\n`
    msg += `📄 الصفحة ${page + 1}/${total} \\(${activities.length} نشاط\\)\n${sep()}\n\n`

    for (const a of slice) {
      msg += `📌 ${bold(a.title || 'بدون عنوان')}\n`
      msg += `   📅 ${esc(a.date || '—')}  |  🏷️ ${esc(a.type || '—')}\n\n`
    }

    const kb = new InlineKeyboard()
    if (page > 0) kb.text('⬅️ السابق', `act_page_${page - 1}`)
    if (page < total - 1) kb.text('➡️ التالي', `act_page_${page + 1}`)
    kb.row().text('🏠 القائمة الرئيسية', 'back_main')

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: kb })
  } catch (e) {
    console.error('Activities list error:', e)
    await ctx.reply('❌ حدث خطأ', { parse_mode: 'MarkdownV2' })
  }
}

async function startAddActivity(ctx: any, chatId: number) {
  const st = getState(chatId)
  st.section = 'activities'
  st.action = 'add_activity'
  st.step = 1
  st.data = {}

  await ctx.reply(
    `➕ ${bold('إضافة نشاط جديد')}\n\n` +
    `📋 ${bold('الخطوة 1 من 4')}\n\n📌 أدخل عنوان النشاط:`,
    { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
  )
}

async function handleAddActivityText(ctx: any, text: string) {
  const chatId = ctx.chat!.id
  const st = getState(chatId)

  switch (st.step) {
    case 1: {
      st.data.title = text.trim()
      st.step = 2
      await ctx.reply(
        `➕ ${bold('إضافة نشاط جديد')}\n\n` +
        `📋 ${bold('الخطوة 2 من 4')}\n\n📅 أدخل التاريخ \\(مثال: 2025-01-15\\):`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
    case 2: {
      st.data.date = text.trim()
      st.step = 3
      await ctx.reply(
        `➕ ${bold('إضافة نشاط جديد')}\n\n` +
        `📋 ${bold('الخطوة 3 من 4')}\n\n📝 أدخل وصف النشاط:`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
    case 3: {
      st.data.description = text.trim()
      st.step = 4
      const kb = new InlineKeyboard()
      ACTIVITY_TYPES.forEach((t) => kb.text(t, `act_type_${t}`).row())
      kb.row().text('❌ إلغاء', 'cancel')
      await ctx.reply(
        `➕ ${bold('إضافة نشاط جديد')}\n\n` +
        `📋 ${bold('الخطوة 4 من 4')}\n\n🏷️ اختر نوع النشاط:`,
        { parse_mode: 'MarkdownV2', reply_markup: kb }
      )
      break
    }
    default: break
  }
}

async function finishAddActivity(ctx: any, chatId: number, st: ChatState) {
  try {
    await sbPost('Activity', {
      title: st.data.title,
      date: st.data.date,
      description: st.data.description,
      type: st.data.type,
    })
    clearState(chatId)

    await ctx.reply(
      `✅ ${bold('تم إضافة النشاط بنجاح\\!')} 🎉\n\n` +
      `📌 ${esc(st.data.title)}\n` +
      `📅 ${esc(st.data.date)}\n` +
      `🏷️ ${esc(st.data.type)}`,
      { parse_mode: 'MarkdownV2' }
    )
  } catch (e) {
    console.error('Add activity error:', e)
    await ctx.reply('❌ حدث خطأ أثناء حفظ النشاط', { parse_mode: 'MarkdownV2' })
  }
}


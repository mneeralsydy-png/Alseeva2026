// ═══════════════════════════════════════════════════════════════════════
// Supabase Helpers
// ═══════════════════════════════════════════════════════════════════════
const sbHeaders = () => ({
  apikey: SUPABASE_KEY,
  Authorization: `Bearer ${SUPABASE_KEY}`,
  'Content-Type': 'application/json',
})

async function sbGet(table: string, query?: string): Promise<any[]> {
  const url = `${SUPABASE_URL}/rest/v1/${table}${query ? '?' + query : ''}`
  const res = await fetch(url, { headers: sbHeaders() })
  if (!res.ok) throw new Error(`Supabase GET error: ${res.status}`)
  return res.json()
}

async function sbPost(table: string, data: Record<string, unknown>): Promise<any> {
  const url = `${SUPABASE_URL}/rest/v1/${table}`
  const res = await fetch(url, {
    method: 'POST',
    headers: { ...sbHeaders(), Prefer: 'return=representation' },
    body: JSON.stringify({
      ...data,
      id: crypto.randomUUID(),
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
    }),
  })
  if (!res.ok) throw new Error(`Supabase POST error: ${res.status}`)
  const result = await res.json()
  return result[0]
}

async function sbPatch(table: string, filter: string, data: Record<string, unknown>): Promise<any> {
  const url = `${SUPABASE_URL}/rest/v1/${table}?${filter}`
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { ...sbHeaders(), Prefer: 'return=representation' },
    body: JSON.stringify({ ...data, updatedAt: new Date().toISOString() }),
  })
  if (!res.ok) throw new Error(`Supabase PATCH error: ${res.status}`)
  const result = await res.json()
  return result[0]
}

async function sbDelete(table: string, filter: string): Promise<void> {
  const url = `${SUPABASE_URL}/rest/v1/${table}?${filter}`
  const res = await fetch(url, { method: 'DELETE', headers: sbHeaders() })
  if (!res.ok) throw new Error(`Supabase DELETE error: ${res.status}`)
}

// ═══════════════════════════════════════════════════════════════════════
// Types & State Management
// ═══════════════════════════════════════════════════════════════════════
interface ChatState {
  section: string
  action: string
  step: number
  data: Record<string, any>
  page: number
}

const chatStates = new Map<number, ChatState>()

function getState(chatId: number): ChatState {
  if (!chatStates.has(chatId)) {
    chatStates.set(chatId, { section: '', action: '', step: 0, data: {}, page: 0 })
  }
  return chatStates.get(chatId)!
}

function clearState(chatId: number) {
  chatStates.delete(chatId)
}

// ═══════════════════════════════════════════════════════════════════════
// MarkdownV2 Utilities
// ═══════════════════════════════════════════════════════════════════════
function esc(text: string): string {
  if (!text) return ''
  return String(text).replace(/([_*\[\]()~`>#+\-=|{}.!\\])/g, '\\$&')
}

function bold(text: string): string {
  return `*${esc(text)}*`
}

function italic(text: string): string {
  return `_${esc(text)}_`
}

function sep(): string {
  return '━━━━━━━━━━━━━━━'
}


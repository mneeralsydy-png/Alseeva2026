// ─── /code — Link admin account ─────────────────────────────────────
bot.command('code', async (ctx) => {
  if (!ctx.chat || ctx.chat.type !== 'private') return
  const parts = ctx.message?.text?.split(' ')
  if (!parts || parts.length < 2) {
    await ctx.reply(
      `❌ الصيغة الصحيحة:\n${esc('/code كلمة_المرور')}`,
      { parse_mode: 'MarkdownV2' }
    )
    return
  }
  const password = parts.slice(1).join(' ')
  try {
    const admins = await sbGet('Admin')
    const admin = admins.find((a: any) => a.password === password)
    if (admin) {
      const chatId = ctx.chat.id
      await sbPatch('Admin', `id=eq.${admin.id}`, { telegramChatId: chatId.toString() })
      authenticatedChats.add(chatId)
      pendingAuth.delete(chatId)
      await loadAuthorizedChats()
      await ctx.reply(
        `✅ تم ربط حسابك بنجاح\\!\n\n` +
        `مرحباً ${bold(admin.name)} 🎉\n` +
        `الآن يمكنك استخدام جميع وظائف البوت`,
        { parse_mode: 'MarkdownV2', reply_markup: getMainMenuKeyboard() }
      )
    } else {
      await ctx.reply('❌ كود خاطئ، تأكد من كلمة المرور', { parse_mode: 'MarkdownV2' })
    }
  } catch (e) {
    console.error('Register error:', e)
    await ctx.reply('❌ حدث خطأ، حاول مرة أخرى', { parse_mode: 'MarkdownV2' })
  }
})

// ═══════════════════════════════════════════════════════════════════════
// Text Message Handler
// ═══════════════════════════════════════════════════════════════════════
bot.on('message:text', async (ctx) => {
  const chatId = ctx.chat!.id
  const text = ctx.message!.text!

  // ── Password authentication flow ─────────────────────────────
  if (pendingAuth.has(chatId)) {
    const password = text.trim()
    try {
      const admins = await sbGet('Admin')
      const admin = admins.find((a: any) => a.password === password)
      if (admin) {
        pendingAuth.delete(chatId)
        authenticatedChats.add(chatId)
        // Save to Supabase
        try {
          await sbPatch('Admin', `id=eq.${admin.id}`, { telegramChatId: chatId.toString() })
        } catch { /* ignore */ }
        await ctx.reply(
          `✅ تم تسجيل الدخول بنجاح\\!\n\n` +
          `مرحباً ${bold(admin.name)} 🎉\n\n` +
          `اختر القسم المطلوب من القائمة أدناه ⬇️`,
          { parse_mode: 'MarkdownV2', reply_markup: getMainMenuKeyboard() }
        )
      } else {
        await ctx.reply(
          '❌ كلمة المرور غير صحيحة\n\n' +
          'حاول مرة أخرى أو أرسل /login لإلغاء',
          { parse_mode: 'MarkdownV2' }
        )
      }
    } catch (e) {
      console.error('Auth error:', e)
      await ctx.reply('❌ حدث خطأ، حاول مرة أخرى', { parse_mode: 'MarkdownV2' })
    }
    return
  }

  // ── Main menu navigation (Reply keyboard) ────────────────────
  if (text === '👥 الطلاب') { clearState(chatId); await showStudentsSection(ctx); return }
  if (text === '📚 الحلقات') { clearState(chatId); await showCirclesSection(ctx); return }
  if (text === '✅ الحضور') { clearState(chatId); await showAttendanceSection(ctx); return }
  if (text === '📊 الإحصائيات') { clearState(chatId); await showStatisticsSection(ctx); return }
  if (text === '📷 الوسائط') { clearState(chatId); await showMediaSection(ctx); return }
  if (text === '📋 الأنشطة') { clearState(chatId); await showActivitiesSection(ctx); return }
  if (text === '⚙️ الإعدادات') { clearState(chatId); await showSettingsSection(ctx); return }
  if (text === '🔐 تسجيل الدخول') { clearState(chatId); pendingAuth.set(chatId, true); await ctx.reply('🔐 أرسل كلمة المرور:', { parse_mode: 'MarkdownV2' }); return }

  // ── Conversation flows ───────────────────────────────────────
  const state = getState(chatId)
  if (!state.action) return

  switch (state.action) {
    case 'add_student':    await handleAddStudentText(ctx, text); break
    case 'add_circle':     await handleAddCircleText(ctx, text); break
    case 'add_activity':   await handleAddActivityText(ctx, text); break
    case 'search_students': await handleSearchStudents(ctx, text); break
    default: break
  }
})

// ═══════════════════════════════════════════════════════════════════════
// Callback Query Handler — ALWAYS answer first!
// ═══════════════════════════════════════════════════════════════════════
bot.on('callback_query:data', async (ctx) => {
  const data = ctx.callbackQuery.data
  const chatId = ctx.callbackQuery.message?.chat.id
  if (!chatId) {
    try { await ctx.answerCallbackQuery() } catch { /* ignore */ }
    return
  }

  // ALWAYS answer callback query immediately to prevent stuck buttons
  try {
    await ctx.answerCallbackQuery()
  } catch {
    // Callback may have expired, that's ok
  }

  try {
    await handleCallback(ctx, chatId, data)
  } catch (e) {
    console.error('Callback error:', e)
    try {
      await ctx.reply('❌ حدث خطأ أثناء معالجة الطلب', { parse_mode: 'MarkdownV2' })
    } catch { /* ignore */ }
  }
})

async function handleCallback(ctx: any, chatId: number, data: string) {
  // ─── Global navigation ──────────────────────────────────────
  if (data === 'back_main') {
    clearState(chatId)
    await ctx.reply(
      `🏠 ${bold('القائمة الرئيسية')}\n\nاختر القسم المطلوب من القائمة أدناه ⬇️`,
      { parse_mode: 'MarkdownV2' }
    )
    return
  }

  if (data === 'cancel') {
    clearState(chatId)
    pendingAuth.delete(chatId)
    await ctx.reply('❌ تم الإلغاء', { parse_mode: 'MarkdownV2' })
    return
  }

  // ─── Students ───────────────────────────────────────────────
  if (data === 'stu_list') { await showStudentsList(ctx, chatId, 0); return }
  if (data === 'stu_add') { await startAddStudent(ctx, chatId); return }
  if (data === 'stu_search') { await startSearchStudents(ctx, chatId); return }
  if (data.startsWith('stu_page_')) { await showStudentsList(ctx, chatId, parseInt(data.split('_')[2])); return }

  // Category selection (step 4)
  if (data.startsWith('stu_cat_')) {
    const val = data.replace('stu_cat_', '')
    const st = getState(chatId)
    if (st.action === 'add_student' && st.step === 4) {
      st.data.category = val
      st.step = 5
      const kb = new InlineKeyboard()
      LEVELS.forEach((l) => kb.text(l, `stu_lvl_${l}`).row())
      kb.row().text('❌ إلغاء', 'cancel')
      await ctx.reply(
        `➕ ${bold('إضافة طالب جديد')}\n\n` +
        `👨‍🎓 ${bold('الخطوة 5 من 8')}\n\n📊 اختر مستوى الطالب:`,
        { parse_mode: 'MarkdownV2', reply_markup: kb }
      )
    }
    return
  }

  // Level selection (step 5)
  if (data.startsWith('stu_lvl_')) {
    const val = data.replace('stu_lvl_', '')
    const st = getState(chatId)
    if (st.action === 'add_student' && st.step === 5) {
      st.data.level = val
      st.step = 6
      await ctx.reply(
        `➕ ${bold('إضافة طالب جديد')}\n\n` +
        `👨‍🎓 ${bold('الخطوة 6 من 8')}\n\n👨‍👩‍👦 أدخل اسم ولي الأمر:`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
    }
    return
  }

  // Halaka selection (step 8)
  if (data.startsWith('stu_hal_')) {
    const hid = data.replace('stu_hal_', '')
    const st = getState(chatId)
    if (st.action === 'add_student' && st.step === 8) {
      st.data.halakaId = hid
      await finishAddStudent(ctx, chatId, st)
    }
    return
  }

  if (data.startsWith('stu_hpage_')) {
    const pg = parseInt(data.split('_')[2])
    const st = getState(chatId)
    if (st.action === 'add_student' && st.step === 8) {
      await showHalakaPicker(ctx, chatId, pg)
    }
    return
  }

  // ─── Circles ────────────────────────────────────────────────
  if (data === 'cir_list') { await showCirclesList(ctx, chatId, 0); return }
  if (data === 'cir_add') { await startAddCircle(ctx, chatId); return }
  if (data.startsWith('cir_page_')) { await showCirclesList(ctx, chatId, parseInt(data.split('_')[2])); return }

  // Branch selection (step 5)
  if (data.startsWith('cir_branch_')) {
    const val = data.replace('cir_branch_', '')
    const st = getState(chatId)
    if (st.action === 'add_circle' && st.step === 5) {
      st.data.branch = val
      await finishAddCircle(ctx, chatId, st)
    }
    return
  }

  // ─── Attendance ─────────────────────────────────────────────
  if (data === 'att_today') { await showAttHalakat(ctx, chatId, 'today'); return }
  if (data === 'att_report') { await showAttHalakat(ctx, chatId, 'report'); return }

  if (data.startsWith('att_hsel_')) {
    const parts = data.replace('att_hsel_', '').split('_')
    const halakaId = parts[0]
    const mode = parts[1]
    if (mode === 'today') {
      await showAttStudents(ctx, chatId, halakaId, 0)
    } else {
      await showAttReport(ctx, chatId, halakaId)
    }
    return
  }

  // Mark attendance — now with answerCallbackQuery already called
  if (data.startsWith('att_mark_')) {
    const parts = data.split('_')
    const studentId = parts[2]
    const halakaId = parts[3]
    const status = parts[4]
    await markAttendance(ctx, chatId, studentId, halakaId, status)
    return
  }

  if (data.startsWith('att_pg_')) {
    const parts = data.split('_')
    const halakaId = parts[2]
    const page = parseInt(parts[3])
    await showAttStudents(ctx, chatId, halakaId, page)
    return
  }

  // ─── Media ──────────────────────────────────────────────────
  if (data === 'med_upload') {
    const st = getState(chatId)
    st.section = 'media'
    st.action = 'upload_photo'
    await ctx.reply(
      `📷 ${bold('رفع صورة')}\n\nأرسل الصورة الآن وسيتم حفظها في القناة\nاختر الألبوم بعد الإرسال`,
      { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
    )
    return
  }
  if (data === 'med_albums') { await showAlbums(ctx, chatId); return }

  // Save media to album — now with answerCallbackQuery already called
  if (data.startsWith('savemed_')) {
    const idx = parseInt(data.replace('savemed_', ''))
    await saveMediaToAlbum(ctx, chatId, idx)
    return
  }

  // ─── Activities ─────────────────────────────────────────────
  if (data === 'act_list') { await showActivitiesList(ctx, chatId, 0); return }
  if (data === 'act_add') { await startAddActivity(ctx, chatId); return }
  if (data.startsWith('act_page_')) { await showActivitiesList(ctx, chatId, parseInt(data.split('_')[2])); return }

  // Type selection (step 4)
  if (data.startsWith('act_type_')) {
    const val = data.replace('act_type_', '')
    const st = getState(chatId)
    if (st.action === 'add_activity' && st.step === 4) {
      st.data.type = val
      await finishAddActivity(ctx, chatId, st)
    }
    return
  }

  // ─── Settings ───────────────────────────────────────────────
  if (data === 'set_info') { await showBotInfo(ctx, chatId); return }
  if (data === 'set_admin') {
    await ctx.reply(
      `🔐 ${bold('ربط حساب إداري')}\n\n` +
      `لربط حساب تيلجرام بالإدارة، أرسل:\n` +
      `${esc('/code كلمة_المرور')}\n\n` +
      `تتوفر كلمات المرور من مدير النظام`,
      { parse_mode: 'MarkdownV2', reply_markup: backBtn() }
    )
    return
  }
}

// ═══════════════════════════════════════════════════════════════════════
// Photo Handler
// ═══════════════════════════════════════════════════════════════════════
bot.on('message:photo', async (ctx) => {
  const chatId = ctx.chat?.id
  if (!chatId) return

  const state = getState(chatId)
  if (state.action !== 'upload_photo') return

  const photo = ctx.message.photo
  if (!photo || photo.length === 0) return

  const highestRes = photo[photo.length - 1]
  pendingMedia.set(chatId, {
    chatId,
    messageId: ctx.message.message_id,
    fileId: highestRes.file_id,
    caption: ctx.message.caption || undefined,
  })

  const kb = new InlineKeyboard()
  for (let i = 0; i < ALBUMS.length; i += 3) {
    kb.text(ALBUMS[i], `savemed_${i}`)
    if (i + 1 < ALBUMS.length) kb.text(ALBUMS[i + 1], `savemed_${i + 1}`)
    if (i + 2 < ALBUMS.length) kb.text(ALBUMS[i + 2], `savemed_${i + 2}`)
    kb.row()
  }
  kb.row().text('❌ إلغاء', 'cancel')

  await ctx.reply(
    `📁 ${bold('اختر الألبوم لحفظ الصورة:')}`,
    { parse_mode: 'MarkdownV2', reply_markup: kb }
  )
})

// ═══════════════════════════════════════════════════════════════════════
// SECTION: Students
// ═══════════════════════════════════════════════════════════════════════
async function showStudentsSection(ctx: any) {
  const state = getState(ctx.chat!.id)
  state.section = 'students'

  const kb = new InlineKeyboard()
    .text('📋 عرض الطلاب', 'stu_list')
    .text('➕ إضافة طالب', 'stu_add')
    .row()
    .text('🔍 بحث عن طالب', 'stu_search')
    .row()
    .text('🏠 القائمة الرئيسية', 'back_main')

  await ctx.reply(
    `👥 ${bold('قسم الطلاب')}\n\n` +
    `إدارة طلاب مركز الشفاء\n` +
    `عرض، إضافة، والبحث في بيانات الطلاب`,
    { parse_mode: 'MarkdownV2', reply_markup: kb }
  )
}

async function showStudentsList(ctx: any, chatId: number, page: number) {
  try {
    const students = await sbGet('Student', 'order=createdAt.desc')
    const halakat = await sbGet('Halaka')
    const hMap = new Map(halakat.map((h: any) => [h.id, h.name]))

    if (students.length === 0) {
      await ctx.reply(
        `📋 ${bold('قائمة الطلاب')}\n\nلا يوجد طلاب مسجلين بعد`,
        { parse_mode: 'MarkdownV2', reply_markup: backBtn() }
      )
      return
    }

    const total = Math.ceil(students.length / PAGE_SIZE)
    const slice = students.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE)

    let msg = `📋 ${bold('قائمة الطلاب')}\n`
    msg += `📄 الصفحة ${page + 1}/${total} \\(${students.length} طالب\\)\n`
    msg += `${sep()}\n\n`

    slice.forEach((s: any, i: number) => {
      const num = page * PAGE_SIZE + i + 1
      const hName = hMap.get(s.halakaId) || '—'
      msg += `${num}\\. ${bold(s.name || 'بدون اسم')}\n`
      msg += `   📊 ${esc(s.level || '—')}  |  📖 ${esc(s.category || '—')}\n`
      msg += `   🏫 ${esc(hName)}\n\n`
    })

    const kb = new InlineKeyboard()
    if (page > 0) kb.text('⬅️ السابق', `stu_page_${page - 1}`)
    if (page < total - 1) kb.text('➡️ التالي', `stu_page_${page + 1}`)
    kb.row().text('🏠 القائمة الرئيسية', 'back_main')

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: kb })
  } catch (e) {
    console.error('Students list error:', e)
    await ctx.reply('❌ حدث خطأ في تحميل قائمة الطلاب', { parse_mode: 'MarkdownV2' })
  }
}

// ── Add Student Conversation ──────────────────────────────────
async function startAddStudent(ctx: any, chatId: number) {
  const st = getState(chatId)
  st.section = 'students'
  st.action = 'add_student'
  st.step = 1
  st.data = {}

  await ctx.reply(
    `➕ ${bold('إضافة طالب جديد')}\n\n` +
    `👨‍🎓 ${bold('الخطوة 1 من 8')}\n\n👤 أدخل اسم الطالب:`,
    { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
  )
}

async function handleAddStudentText(ctx: any, text: string) {
  const chatId = ctx.chat!.id
  const st = getState(chatId)

  switch (st.step) {
    case 1: {
      if (!text.trim()) {
        await ctx.reply('❌ الاسم مطلوب، حاول مرة أخرى', { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() })
        return
      }
      st.data.name = text.trim()
      st.step = 2
      await ctx.reply(
        `➕ ${bold('إضافة طالب جديد')}\n\n` +
        `👨‍🎓 ${bold('الخطوة 2 من 8')}\n\n🎂 أدخل عمر الطالب \\(رقم\\):`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
    case 2: {
      const age = parseInt(text.trim())
      if (isNaN(age) || age < 3 || age > 100) {
        await ctx.reply('❌ أدخل عمراً صحيحاً \\(3 \\- 100\\)', { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() })
        return
      }
      st.data.age = age
      st.step = 3
      await ctx.reply(
        `➕ ${bold('إضافة طالب جديد')}\n\n` +
        `👨‍🎓 ${bold('الخطوة 3 من 8')}\n\n📖 أدخل السورة الحالية:`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
    case 3: {
      st.data.surah = text.trim()
      st.step = 4
      const kb = new InlineKeyboard()
      CATEGORIES.forEach((c) => kb.text(c, `stu_cat_${c}`).row())
      kb.row().text('❌ إلغاء', 'cancel')
      await ctx.reply(
        `➕ ${bold('إضافة طالب جديد')}\n\n` +
        `👨‍🎓 ${bold('الخطوة 4 من 8')}\n\n📊 اختر الفئة:`,
        { parse_mode: 'MarkdownV2', reply_markup: kb }
      )
      break
    }
    case 6: {
      if (!text.trim()) {
        await ctx.reply('❌ اسم ولي الأمر مطلوب', { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() })
        return
      }
      st.data.parentName = text.trim()
      st.step = 7
      await ctx.reply(
        `➕ ${bold('إضافة طالب جديد')}\n\n` +
        `👨‍🎓 ${bold('الخطوة 7 من 8')}\n\n📱 أدخل رقم هاتف ولي الأمر:`,
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
    case 7: {
      st.data.parentPhone = text.trim()
      st.step = 8
      await showHalakaPicker(ctx, chatId, 0)
      break
    }
    default: {
      await ctx.reply(
        '👆 الرجاء اختيار الخيار من الأزرار أدناه',
        { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
      )
      break
    }
  }
}

async function showHalakaPicker(ctx: any, chatId: number, page: number) {
  try {
    const halakat = await sbGet('Halaka', 'order=createdAt.desc')
    if (halakat.length === 0) {
      await ctx.reply(
        '❌ لا توجد حلقات مسجلة بعد\\. أضف حلقة أولاً من قسم الحلقات',
        { parse_mode: 'MarkdownV2', reply_markup: backBtn() }
      )
      clearState(chatId)
      return
    }

    const total = Math.ceil(halakat.length / PAGE_SIZE)
    const slice = halakat.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE)

    const kb = new InlineKeyboard()
    slice.forEach((h: any) => {
      kb.text(`🏫 ${h.name} — ${esc(h.teacher || '')}`, `stu_hal_${h.id}`).row()
    })
    if (page > 0) kb.text('⬅️ السابق', `stu_hpage_${page - 1}`)
    if (page < total - 1) kb.text('➡️ التالي', `stu_hpage_${page + 1}`)
    kb.row().text('❌ إلغاء', 'cancel')

    await ctx.reply(
      `➕ ${bold('إضافة طالب جديد')}\n\n` +
      `👨‍🎓 ${bold('الخطوة 8 من 8')}\n\n🏫 اختر الحلقة:`,
      { parse_mode: 'MarkdownV2', reply_markup: kb }
    )
  } catch (e) {
    console.error('Halaka picker error:', e)
    await ctx.reply('❌ حدث خطأ في تحميل الحلقات', { parse_mode: 'MarkdownV2' })
  }
}

async function finishAddStudent(ctx: any, chatId: number, st: ChatState) {
  try {
    await sbPost('Student', {
      name: st.data.name,
      age: st.data.age,
      surah: st.data.surah,
      category: st.data.category,
      level: st.data.level,
      parentName: st.data.parentName,
      parentPhone: st.data.parentPhone,
      halakaId: st.data.halakaId,
    })
    clearState(chatId)

    await ctx.reply(
      `✅ ${bold('تم إضافة الطالب بنجاح\\!')} 🎉\n\n` +
      `👤 الاسم: ${esc(st.data.name)}\n` +
      `🎂 العمر: ${esc(String(st.data.age))}\n` +
      `📖 السورة: ${esc(st.data.surah)}\n` +
      `📊 الفئة: ${esc(st.data.category)}\n` +
      `📈 المستوى: ${esc(st.data.level)}\n` +
      `👨‍👩‍👦 ولي الأمر: ${esc(st.data.parentName)}\n` +
      `📱 الهاتف: ${esc(st.data.parentPhone)}`,
      { parse_mode: 'MarkdownV2' }
    )
  } catch (e) {
    console.error('Add student error:', e)
    await ctx.reply('❌ حدث خطأ أثناء حفظ بيانات الطالب', { parse_mode: 'MarkdownV2' })
  }
}

// ── Search Students ───────────────────────────────────────────
async function startSearchStudents(ctx: any, chatId: number) {
  const st = getState(chatId)
  st.section = 'students'
  st.action = 'search_students'
  st.step = 1

  await ctx.reply(
    `🔍 ${bold('بحث عن طالب')}\n\n👤 أدخل اسم الطالب \\(أو جزء منه\\):`,
    { parse_mode: 'MarkdownV2', reply_markup: cancelBtn() }
  )
}

async function handleSearchStudents(ctx: any, text: string) {
  const chatId = ctx.chat!.id
  try {
    const q = text.trim()
    if (!q) {
      await ctx.reply('❌ أدخل اسم للبحث', { parse_mode: 'MarkdownV2' })
      return
    }

    const students = await sbGet('Student', `name=ilike.*${encodeURIComponent(q)}*`)
    const halakat = await sbGet('Halaka')
    const hMap = new Map(halakat.map((h: any) => [h.id, h.name]))
    clearState(chatId)

    if (students.length === 0) {
      await ctx.reply(
        `🔍 ${bold('نتائج البحث')}\n\nلم يتم العثور على طالب باسم "${esc(q)}"`,
        { parse_mode: 'MarkdownV2', reply_markup: backBtn() }
      )
      return
    }

    let msg = `🔍 ${bold('نتائج البحث')} \\(${students.length}\\)\n${sep()}\n\n`
    students.slice(0, 10).forEach((s: any, i: number) => {
      const hName = hMap.get(s.halakaId) || '—'
      msg += `${i + 1}\\. ${bold(s.name || 'بدون اسم')}\n`
      msg += `   📊 ${esc(s.level || '—')}  |  📖 ${esc(s.category || '—')}\n`
      msg += `   🏫 ${esc(hName)}\n\n`
    })
    if (students.length > 10) {
      msg += `\\.\\.\\. و ${esc(String(students.length - 10))} نتائج أخرى`
    }

    await ctx.reply(msg, { parse_mode: 'MarkdownV2', reply_markup: backBtn() })
  } catch (e) {
    console.error('Search error:', e)
    await ctx.reply('❌ حدث خطأ في البحث', { parse_mode: 'MarkdownV2' })
  }
}

